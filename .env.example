# ── Agent behaviour ───────────────────────────────────────────────────────────
SCAN_INTERVAL_MS=60000        # How often to re-scan all chains (ms)
TOP_N=20                      # How many pools to keep in the ranked list
MAX_SLIPPAGE_BPS=50           # Default max slippage (50 = 0.5%)
AGENT_API_PORT=3001           # REST API port

# NETWORK_FILTER=all          # "all" | "mainnet" | "testnet"  (default: all)

# ── Mainnet RPC endpoints ─────────────────────────────────────────────────────
# Public fallbacks are built in. Paid endpoints recommended for production.
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
UNICHAIN_RPC_URL=https://mainnet.unichain.org
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
BLAST_RPC_URL=https://rpc.blast.io
AVAX_RPC_URL=https://api.avax.network/ext/bc/C/rpc
BSC_RPC_URL=https://bsc-dataseed.binance.org
CELO_RPC_URL=https://forno.celo.org
ZORA_RPC_URL=https://rpc.zora.energy
WORLDCHAIN_RPC_URL=https://worldchain-mainnet.g.alchemy.com/public
INK_RPC_URL=https://rpc-gel.inkonchain.com
SONEIUM_RPC_URL=https://rpc.soneium.org

# ── Testnet RPC endpoints ─────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_API_URL=http://localhost:3001
NEXT_PUBLIC_WALLET_CONNECT_ID=your_walletconnect_project_id
