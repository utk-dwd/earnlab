{
  "name": "earngen-yield-hunter",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "start":       "ts-node src/index.ts",
    "start:mainnet": "NETWORK_FILTER=mainnet ts-node src/index.ts",
    "start:testnet": "NETWORK_FILTER=testnet ts-node src/index.ts",
    "build":       "tsc",
    "dev":         "ts-node-dev --respawn --transpile-only src/index.ts"
  },
  "dependencies": {
    "axios":          "^1.6.0",
    "better-sqlite3": "^9.4.3",
    "cors":           "^2.8.5",
    "dotenv":         "^16.3.1",
    "express":        "^4.18.2",
    "js-yaml":        "^4.1.0",
    "viem":           "^2.9.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors":           "^2.8.17",
    "@types/express":        "^4.17.21",
    "@types/js-yaml":        "^4.0.9",
    "@types/node":           "^20.11.0",
    "ts-node":               "^10.9.2",
    "ts-node-dev":           "^2.0.0",
    "typescript":            "^5.3.3"
  }
}
